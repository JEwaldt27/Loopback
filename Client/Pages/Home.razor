    private void NewDiagram()
    {
        if (_diagram.Nodes.Count > 0 || _diagram.Links.Count > 0)
            PushUndoSnapshot();
        _diagram.Nodes.Clear();
        _diagram.Links.Clear();
        _createdBy = "";
        _createdAt = null;
        _modifiedBy = "";
        _modifiedAt = null;
        MarkClean();
