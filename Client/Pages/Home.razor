    // Per-item serializers, shared by full-diagram saves/snapshots (BuildDiagramData) and
    // by clipboard copy (CopySelection) so both produce identical JSON shapes.
    private object NodeToJson(LineFlowNode n) => new
    {
        id = n.Id,
        manufacturer = n.Device.Manufacturer,
        model = n.Device.Model,
        category = n.Device.Category,
        ports = n.Device.Ports,
        x = n.Position.X,
        y = n.Position.Y
    };

    private object LinkToJson(BaseLinkModel l) => new
    {
        sourceNodeId = (l.Source.Model as PortModel)?.Parent.Id,
        sourcePortIndex = (l.Source.Model as PortModel) is PortModel sp
            ? sp.Parent.Ports.ToList().IndexOf(sp) : 0,
        targetNodeId = (l.Target!.Model as PortModel)?.Parent.Id,
        targetPortIndex = (l.Target.Model as PortModel) is PortModel tp
            ? tp.Parent.Ports.ToList().IndexOf(tp) : 0,
        vertices = l.Vertices.Select(v => new { x = v.Position.X, y = v.Position.Y }),
        label = (l as ElbowLinkModel)?.LabelText ?? "",
        labelX = (l as ElbowLinkModel)?.LabelNode?.Position.X,
        labelY = (l as ElbowLinkModel)?.LabelNode?.Position.Y
    };

    private object BoxToJson(BoxNode b) => new
    {
        x = b.Position.X,
        y = b.Position.Y,
        width = b.Size?.Width ?? 160,
        height = b.Size?.Height ?? 100,
        borderColor = b.BorderColor
    };

    private object LineToJson(LineNode l) => new
    {
        x = l.Position.X,
        y = l.Position.Y,
        startX = l.Start.X,
        startY = l.Start.Y,
        endX = l.End.X,
        endY = l.End.Y,
        strokeColor = l.StrokeColor
    };

    private object TextToJson(TextNode t) => new
    {
        x = t.Position.X,
        y = t.Position.Y,
        text = t.Text,
        fontSize = t.FontSize,
        color = t.Color
    };

    // Shared serializer for both .lf file saves and undo/redo snapshots. Meta is only
    // added by SaveDiagram — snapshots deliberately exclude it so undo never rewrites
    // the created-by/modified-by info bar.
    private Dictionary<string, object?> BuildDiagramData()
    {
        return new Dictionary<string, object?>
        {
            ["nodes"] = _diagram.Nodes.OfType<LineFlowNode>().Select(NodeToJson).ToList(),
            // Skip links still being dragged (target not attached to a port yet)
            ["links"] = _diagram.Links
                .Where(l => l.Source.Model is PortModel && l.Target?.Model is PortModel)
                .Select(LinkToJson).ToList(),
            ["boxes"] = _diagram.Nodes.OfType<BoxNode>().Select(BoxToJson).ToList(),
            ["lines"] = _diagram.Nodes.OfType<LineNode>().Select(LineToJson).ToList(),
            ["texts"] = _diagram.Nodes.OfType<TextNode>().Select(TextToJson).ToList(),
            ["legend"] = _diagram.Nodes.OfType<LegendNode>().Select(g => new
            {
                x = g.Position.X,
                y = g.Position.Y,
                entries = g.Entries.Select(en => new { type = en.Type, color = en.Color }).ToList()
            }).FirstOrDefault()
        };
    }

    private string SerializeDiagramState()
        => JsonSerializer.Serialize(BuildDiagramData());

    private bool CanPaste => _clipboardJson != null;

    // Copies the currently-selected nodes (devices + box/line/text annotations) to an in-app
    // clipboard. Connections are included only when BOTH of their endpoints are among the
    // copied devices, so duplicating a connected group brings the wiring along. The legend and
    // connection-label nodes are intentionally not copyable.
    private void CopySelection()
    {
        var deviceNodes = _diagram.Nodes.OfType<LineFlowNode>().Where(n => n.Selected).ToList();
        var boxNodes = _diagram.Nodes.OfType<BoxNode>().Where(n => n.Selected).ToList();
        var lineNodes = _diagram.Nodes.OfType<LineNode>().Where(n => n.Selected).ToList();
        var textNodes = _diagram.Nodes.OfType<TextNode>().Where(n => n.Selected).ToList();

        if (deviceNodes.Count + boxNodes.Count + lineNodes.Count + textNodes.Count == 0)
            return;

        var deviceIds = deviceNodes.Select(n => n.Id).ToHashSet();
        var links = _diagram.Links.Where(l =>
            l.Source.Model is PortModel sp && l.Target?.Model is PortModel tp &&
            deviceIds.Contains(sp.Parent.Id) && deviceIds.Contains(tp.Parent.Id)).ToList();

        var data = new Dictionary<string, object?>
        {
            ["nodes"] = deviceNodes.Select(NodeToJson).ToList(),
            ["links"] = links.Select(LinkToJson).ToList(),
            ["boxes"] = boxNodes.Select(BoxToJson).ToList(),
            ["lines"] = lineNodes.Select(LineToJson).ToList(),
            ["texts"] = textNodes.Select(TextToJson).ToList()
        };
        _clipboardJson = JsonSerializer.Serialize(data);
        _pasteSequence = 0;
    }

    // Pastes the clipboard onto the canvas, offset from the originals and re-selected so the
    // copy can be dragged immediately. Undoable. Repeated pastes step the offset so they don't
    // stack. Device nodes get fresh ids; copied connections are re-created against the new nodes.
    private void PasteClipboard()
    {
        if (_clipboardJson == null) return;
        var doc = JsonDocument.Parse(_clipboardJson);

        _pasteSequence++;
        double off = 30 * _pasteSequence;

        PushUndoSnapshot();
        _diagram.UnselectAll();

        var newNodes = new List<NodeModel>();
        var idMap = new Dictionary<string, LineFlowNode>();

        foreach (var nodeEl in doc.RootElement.GetProperty("nodes").EnumerateArray())
        {
            var oldId = nodeEl.GetProperty("id").GetString()!;
            var device = new DeviceDefinition
            {
                Manufacturer = nodeEl.GetProperty("manufacturer").GetString() ?? "",
                Model = nodeEl.GetProperty("model").GetString() ?? "",
                Category = nodeEl.GetProperty("category").GetString() ?? "",
                Ports = nodeEl.GetProperty("ports").Deserialize<List<PortDefinition>>() ?? new()
            };
            var node = new LineFlowNode(
                new Point(nodeEl.GetProperty("x").GetDouble() + off, nodeEl.GetProperty("y").GetDouble() + off), device);
            _diagram.Nodes.Add(node);
            idMap[oldId] = node;
            newNodes.Add(node);
        }

        foreach (var linkEl in doc.RootElement.GetProperty("links").EnumerateArray())
        {
            var sourceNodeId = linkEl.GetProperty("sourceNodeId").GetString()!;
            var sourcePortIndex = linkEl.GetProperty("sourcePortIndex").GetInt32();
            var targetNodeId = linkEl.GetProperty("targetNodeId").GetString()!;
            var targetPortIndex = linkEl.GetProperty("targetPortIndex").GetInt32();

            if (idMap.TryGetValue(sourceNodeId, out var sourceNode) &&
                idMap.TryGetValue(targetNodeId, out var targetNode) &&
                sourcePortIndex < sourceNode.Ports.Count &&
                targetPortIndex < targetNode.Ports.Count)
            {
                var link = new ElbowLinkModel(
                    (PortModel)sourceNode.Ports[sourcePortIndex],
                    (PortModel)targetNode.Ports[targetPortIndex]);

                if (linkEl.TryGetProperty("vertices", out var vertsEl))
                {
                    foreach (var v in vertsEl.EnumerateArray())
                        link.Vertices.Add(new LinkVertexModel(link,
                            new Point(v.GetProperty("x").GetDouble() + off, v.GetProperty("y").GetDouble() + off)));
                }

                _diagram.Links.Add(link);

                if (linkEl.TryGetProperty("label", out var labelEl) && labelEl.ValueKind == JsonValueKind.String)
                {
                    var labelText = labelEl.GetString();
                    if (!string.IsNullOrEmpty(labelText))
                    {
                        link.LabelText = labelText;
                        var labelPos = linkEl.TryGetProperty("labelX", out var lxEl) && lxEl.ValueKind != JsonValueKind.Null &&
                                        linkEl.TryGetProperty("labelY", out var lyEl) && lyEl.ValueKind != JsonValueKind.Null
                            ? new Point(lxEl.GetDouble() + off, lyEl.GetDouble() + off)
                            : ComputeLinkMidpoint(link);
                        var labelNode = new ConnectionLabelNode(labelPos) { Text = labelText, OwnerLink = link };
                        link.LabelNode = labelNode;
                        _diagram.Nodes.Add(labelNode);
                    }
                }
            }
        }

        foreach (var b in doc.RootElement.GetProperty("boxes").EnumerateArray())
        {
            var box = new BoxNode(new Point(b.GetProperty("x").GetDouble() + off, b.GetProperty("y").GetDouble() + off))
            {
                Size = new Blazor.Diagrams.Core.Geometry.Size(b.GetProperty("width").GetDouble(), b.GetProperty("height").GetDouble()),
                BorderColor = b.TryGetProperty("borderColor", out var bc) ? bc.GetString() ?? "#e94560" : "#e94560"
            };
            _diagram.Nodes.Add(box);
            newNodes.Add(box);
        }

        foreach (var l in doc.RootElement.GetProperty("lines").EnumerateArray())
        {
            var line = new LineNode(new Point(l.GetProperty("x").GetDouble() + off, l.GetProperty("y").GetDouble() + off))
            {
                Start = new Point(l.GetProperty("startX").GetDouble(), l.GetProperty("startY").GetDouble()),
                End = new Point(l.GetProperty("endX").GetDouble(), l.GetProperty("endY").GetDouble()),
                StrokeColor = l.TryGetProperty("strokeColor", out var sc) ? sc.GetString() ?? "#333333" : "#333333"
            };
            line.Size = new Blazor.Diagrams.Core.Geometry.Size(
                Math.Max(Math.Abs(line.End.X - line.Start.X), 1),
                Math.Max(Math.Abs(line.End.Y - line.Start.Y), 1));
            _diagram.Nodes.Add(line);
            newNodes.Add(line);
        }

        foreach (var t in doc.RootElement.GetProperty("texts").EnumerateArray())
        {
            var text = new TextNode(new Point(t.GetProperty("x").GetDouble() + off, t.GetProperty("y").GetDouble() + off))
            {
                Text = t.GetProperty("text").GetString() ?? "Text",
                FontSize = t.TryGetProperty("fontSize", out var fs) ? fs.GetInt32() : 16,
                Color = t.TryGetProperty("color", out var c) ? c.GetString() ?? "#222222" : "#222222"
            };
            _diagram.Nodes.Add(text);
            newNodes.Add(text);
        }

        foreach (var n in newNodes)
            _diagram.SelectModel(n, false);

        StateHasChanged();
    }

    private void DuplicateContextNode()
    {
        _contextMenuVisible = false;
        // Duplicate the whole selection; if the right-clicked node isn't part of it, act on just it.
        if (_contextNode != null && !_contextNode.Selected)
        {
            _diagram.UnselectAll();
            _diagram.SelectModel(_contextNode, false);
        }
        _contextNode = null;
        CopySelection();
        PasteClipboard();
    }

    private async Task SaveDiagram()
    {
        var now = DateTimeOffset.UtcNow;
        if (string.IsNullOrEmpty(_createdBy))
        {
            _createdBy = _currentUsername;
            _createdAt = now;
        }
        _modifiedBy = _currentUsername;
        _modifiedAt = now;

        var data = BuildDiagramData();
        data["meta"] = new
        {
            createdBy = _createdBy,
            createdAt = _createdAt,
            modifiedBy = _modifiedBy,
            modifiedAt = _modifiedAt
        };

        var json = JsonSerializer.Serialize(data,
            new JsonSerializerOptions { WriteIndented = true });

        await JS.InvokeVoidAsync("saveAsFile", "diagram.lf", json);
        MarkClean();
    }

    private async Task OpenDiagram(InputFileChangeEventArgs e)
    {
        using var stream = e.File.OpenReadStream();
        using var reader = new System.IO.StreamReader(stream);
        var json = await reader.ReadToEndAsync();

        if (_diagram.Nodes.Count > 0 || _diagram.Links.Count > 0)
            PushUndoSnapshot();

        // Older files saved before metadata tracking simply leave these reset.
        _createdBy = "";
        _createdAt = null;
        _modifiedBy = "";
        _modifiedAt = null;

        LoadDiagramJson(json);
        MarkClean();
    }

    // Rebuilds the entire canvas from serialized diagram JSON. Used by both file open
    // and undo/redo restore (snapshots have no meta property, so meta is left alone).
    private void LoadDiagramJson(string json)
    {
        var doc = JsonDocument.Parse(json);

        _diagram.Nodes.Clear();
        _diagram.Links.Clear();

        if (doc.RootElement.TryGetProperty("meta", out var metaEl) && metaEl.ValueKind == JsonValueKind.Object)
        {
            _createdBy = metaEl.TryGetProperty("createdBy", out var cb) ? cb.GetString() ?? "" : "";
            _createdAt = metaEl.TryGetProperty("createdAt", out var ca) && ca.ValueKind != JsonValueKind.Null ? ca.GetDateTimeOffset() : null;
            _modifiedBy = metaEl.TryGetProperty("modifiedBy", out var mb) ? mb.GetString() ?? "" : "";
            _modifiedAt = metaEl.TryGetProperty("modifiedAt", out var ma) && ma.ValueKind != JsonValueKind.Null ? ma.GetDateTimeOffset() : null;
        }

        var nodeMap = new Dictionary<string, LineFlowNode>();

        foreach (var nodeEl in doc.RootElement.GetProperty("nodes").EnumerateArray())
        {
            var id = nodeEl.GetProperty("id").GetString()!;
            var x = nodeEl.GetProperty("x").GetDouble();
            var y = nodeEl.GetProperty("y").GetDouble();

            var device = new DeviceDefinition
            {
                Manufacturer = nodeEl.GetProperty("manufacturer").GetString() ?? "",
                Model = nodeEl.GetProperty("model").GetString() ?? "",
                Category = nodeEl.GetProperty("category").GetString() ?? "",
                Ports = nodeEl.GetProperty("ports").Deserialize<List<PortDefinition>>() ?? new()
            };

            var node = new LineFlowNode(new Point(x, y), device);
            _diagram.Nodes.Add(node);
            nodeMap[id] = node;
        }

        foreach (var linkEl in doc.RootElement.GetProperty("links").EnumerateArray())
        {
            var sourceNodeId = linkEl.GetProperty("sourceNodeId").GetString()!;
            var sourcePortIndex = linkEl.GetProperty("sourcePortIndex").GetInt32();
            var targetNodeId = linkEl.GetProperty("targetNodeId").GetString()!;
            var targetPortIndex = linkEl.GetProperty("targetPortIndex").GetInt32();

            if (nodeMap.TryGetValue(sourceNodeId, out var sourceNode) &&
                nodeMap.TryGetValue(targetNodeId, out var targetNode) &&
                sourcePortIndex < sourceNode.Ports.Count &&
                targetPortIndex < targetNode.Ports.Count)
            {
                var link = new ElbowLinkModel(
                    (PortModel)sourceNode.Ports[sourcePortIndex],
                    (PortModel)targetNode.Ports[targetPortIndex]);

                // Restore vertices (new format)
                if (linkEl.TryGetProperty("vertices", out var vertsEl))
                {
                    foreach (var v in vertsEl.EnumerateArray())
                        link.Vertices.Add(new LinkVertexModel(link, new Point(v.GetProperty("x").GetDouble(), v.GetProperty("y").GetDouble())));
                }
                // Backward compat: old files saved midX only
                else if (linkEl.TryGetProperty("midX", out var midXEl) && midXEl.ValueKind != JsonValueKind.Null)
                {
                    link.MidX = midXEl.GetDouble();
                }

                _diagram.Links.Add(link);

                if (linkEl.TryGetProperty("label", out var labelEl) && labelEl.ValueKind == JsonValueKind.String)
                {
                    var labelText = labelEl.GetString();
                    if (!string.IsNullOrEmpty(labelText))
                    {
                        link.LabelText = labelText;
                        var labelPos = linkEl.TryGetProperty("labelX", out var lxEl) && lxEl.ValueKind != JsonValueKind.Null &&
                                        linkEl.TryGetProperty("labelY", out var lyEl) && lyEl.ValueKind != JsonValueKind.Null
                            ? new Point(lxEl.GetDouble(), lyEl.GetDouble())
                            : ComputeLinkMidpoint(link);
                        var labelNode = new ConnectionLabelNode(labelPos) { Text = labelText, OwnerLink = link };
                        link.LabelNode = labelNode;
                        _diagram.Nodes.Add(labelNode);
                    }
                }
            }
        }

        if (doc.RootElement.TryGetProperty("boxes", out var boxesEl))
        {
            foreach (var b in boxesEl.EnumerateArray())
            {
                var box = new BoxNode(new Point(b.GetProperty("x").GetDouble(), b.GetProperty("y").GetDouble()))
                {
                    Size = new Blazor.Diagrams.Core.Geometry.Size(b.GetProperty("width").GetDouble(), b.GetProperty("height").GetDouble()),
                    BorderColor = b.TryGetProperty("borderColor", out var bc) ? bc.GetString() ?? "#e94560" : "#e94560"
                };
                _diagram.Nodes.Add(box);
            }
        }

        if (doc.RootElement.TryGetProperty("lines", out var linesEl))
        {
            foreach (var l in linesEl.EnumerateArray())
            {
                var line = new LineNode(new Point(l.GetProperty("x").GetDouble(), l.GetProperty("y").GetDouble()))
                {
                    Start = new Point(l.GetProperty("startX").GetDouble(), l.GetProperty("startY").GetDouble()),
                    End = new Point(l.GetProperty("endX").GetDouble(), l.GetProperty("endY").GetDouble()),
                    StrokeColor = l.TryGetProperty("strokeColor", out var sc) ? sc.GetString() ?? "#333333" : "#333333"
                };
                line.Size = new Blazor.Diagrams.Core.Geometry.Size(
                    Math.Max(Math.Abs(line.End.X - line.Start.X), 1),
                    Math.Max(Math.Abs(line.End.Y - line.Start.Y), 1));
                _diagram.Nodes.Add(line);
            }
        }

        if (doc.RootElement.TryGetProperty("texts", out var textsEl))
        {
            foreach (var t in textsEl.EnumerateArray())
            {
                var text = new TextNode(new Point(t.GetProperty("x").GetDouble(), t.GetProperty("y").GetDouble()))
                {
                    Text = t.GetProperty("text").GetString() ?? "Text",
                    FontSize = t.TryGetProperty("fontSize", out var fs) ? fs.GetInt32() : 16,
                    Color = t.TryGetProperty("color", out var c) ? c.GetString() ?? "#222222" : "#222222"
                };
                _diagram.Nodes.Add(text);
            }
        }

        if (doc.RootElement.TryGetProperty("legend", out var legendEl) && legendEl.ValueKind == JsonValueKind.Object)
        {
            var legend = new LegendNode(new Point(legendEl.GetProperty("x").GetDouble(), legendEl.GetProperty("y").GetDouble()));
            if (legendEl.TryGetProperty("entries", out var entriesEl))
            {
                foreach (var en in entriesEl.EnumerateArray())
                    legend.Entries.Add((en.GetProperty("type").GetString() ?? "", en.GetProperty("color").GetString() ?? "#e94560"));
            }
            _diagram.Nodes.Add(legend);
        }

        StateHasChanged();
    }

    // Exports a cable schedule (pull sheet) as CSV: one row per connection with its label,
    // signal type, and the source/destination device + port. Sorted by source device then
    // source port so cables from the same box group together.
    private async Task ExportCableSchedule()
    {
        static string Csv(string? s)
        {
            s ??= "";
            return s.Contains(',') || s.Contains('"') || s.Contains('\n') || s.Contains('\r')
                ? "\"" + s.Replace("\"", "\"\"") + "\""
                : s;
        }

        var rows = _diagram.Links
            .Where(l => l.Source.Model is LineFlowPort && l.Target?.Model is LineFlowPort)
            .Select(l =>
            {
                var sp = (LineFlowPort)l.Source.Model!;
                var tp = (LineFlowPort)l.Target!.Model!;
                return new
                {
                    Cable = (l as ElbowLinkModel)?.LabelText ?? "",
                    Signal = sp.Definition.Type,
                    FromDevice = sp.Parent.Title ?? "",
                    FromPort = sp.Definition.Name,
                    ToDevice = tp.Parent.Title ?? "",
                    ToPort = tp.Definition.Name
                };
            })
            .OrderBy(r => r.FromDevice, StringComparer.OrdinalIgnoreCase)
            .ThenBy(r => r.FromPort, StringComparer.OrdinalIgnoreCase)
            .ToList();

        var sb = new System.Text.StringBuilder();
        sb.Append('\uFEFF'); // BOM so Excel opens the CSV with correct (UTF-8) encoding
        sb.AppendLine("#,Cable,Signal,From Device,From Port,To Device,To Port");
        int i = 1;
        foreach (var r in rows)
        {
            sb.AppendLine(string.Join(",",
                i++.ToString(), Csv(r.Cable), Csv(r.Signal),
                Csv(r.FromDevice), Csv(r.FromPort), Csv(r.ToDevice), Csv(r.ToPort)));
        }

        await JS.InvokeVoidAsync("saveAsFile", "cable-schedule.csv", sb.ToString());
    }

    private async Task ExportPdf()
    {
        // Save current pan/zoom, reset to default so export renders at 1:1
        var savedZoom = _diagram.Zoom;
        var savedPan = _diagram.Pan;

        _diagram.SetZoom(1.0);
        _diagram.UpdatePan(-savedPan.X, -savedPan.Y);

        await Task.Delay(150); // let diagram re-render before print

        await JS.InvokeVoidAsync("exportToPdf", _diagramTitle);

        // Restore
        _diagram.SetZoom(savedZoom);
        _diagram.UpdatePan(savedPan.X, savedPan.Y);
    }

    private async Task ExportDxf()
    {
        var sb = new System.Text.StringBuilder();

        double scale = 0.3;

        sb.AppendLine("0\nSECTION");
        sb.AppendLine("2\nHEADER");
        sb.AppendLine("9\n$ACADVER");
        sb.AppendLine("1\nAC1015");
        sb.AppendLine("0\nENDSEC");

        sb.AppendLine("0\nSECTION");
        sb.AppendLine("2\nTABLES");
        sb.AppendLine("0\nTABLE");
        sb.AppendLine("2\nLAYER");
        sb.AppendLine("70\n2");
        sb.AppendLine("0\nLAYER");
        sb.AppendLine("2\nNODES");
        sb.AppendLine("70\n0");
        sb.AppendLine("62\n7");
        sb.AppendLine("6\nCONTINUOUS");
        sb.AppendLine("0\nLAYER");
        sb.AppendLine("2\nCONNECTIONS");
        sb.AppendLine("70\n0");
        sb.AppendLine("62\n7");
        sb.AppendLine("6\nCONTINUOUS");
        sb.AppendLine("0\nLAYER");
        sb.AppendLine("2\nANNOTATIONS");
        sb.AppendLine("70\n0");
        sb.AppendLine("62\n7");
        sb.AppendLine("6\nCONTINUOUS");
        sb.AppendLine("0\nENDTAB");
        sb.AppendLine("0\nENDSEC");

        sb.AppendLine("0\nSECTION");
        sb.AppendLine("2\nENTITIES");

        var portPositions = new Dictionary<string, (double x, double y)>();

        void DxfLine(double x1, double y1, double x2, double y2, string layer = "NODES")
        {
            sb.AppendLine("0\nLINE");
            sb.AppendLine($"8\n{layer}");
            sb.AppendLine($"10\n{x1:F4}");
            sb.AppendLine($"20\n{y1:F4}");
            sb.AppendLine("30\n0.0");
            sb.AppendLine($"11\n{x2:F4}");
            sb.AppendLine($"21\n{y2:F4}");
            sb.AppendLine("31\n0.0");
        }

        void DxfText(double tx, double ty, string text, double height = 2.5, string layer = "NODES", int halign = 0)
        {
            sb.AppendLine("0\nTEXT");
            sb.AppendLine($"8\n{layer}");
            sb.AppendLine($"10\n{tx:F4}");
            sb.AppendLine($"20\n{ty:F4}");
            sb.AppendLine("30\n0.0");
            sb.AppendLine($"40\n{height}");
            sb.AppendLine($"1\n{text ?? ""}");
            sb.AppendLine($"72\n{halign}");
            sb.AppendLine($"11\n{tx:F4}");
            sb.AppendLine($"21\n{ty:F4}");
            sb.AppendLine("31\n0.0");
        }

        (double x, double y) PolylineMidpoint(List<(double x, double y)> pts)
        {
            double total = 0;
            for (int i = 0; i < pts.Count - 1; i++)
                total += Math.Sqrt(Math.Pow(pts[i + 1].x - pts[i].x, 2) + Math.Pow(pts[i + 1].y - pts[i].y, 2));

            double target = total / 2;
            double covered = 0;
            for (int i = 0; i < pts.Count - 1; i++)
            {
                double segLen = Math.Sqrt(Math.Pow(pts[i + 1].x - pts[i].x, 2) + Math.Pow(pts[i + 1].y - pts[i].y, 2));
                if (segLen <= 0) continue;
                if (covered + segLen >= target)
                {
                    double t = (target - covered) / segLen;
                    return (pts[i].x + (pts[i + 1].x - pts[i].x) * t, pts[i].y + (pts[i + 1].y - pts[i].y) * t);
                }
                covered += segLen;
            }
            return pts[^1];
        }

        foreach (var node in _diagram.Nodes.OfType<LineFlowNode>())
        {
            var leftPorts = node.Ports.OfType<LineFlowPort>()
                .Where(p => p.Alignment == PortAlignment.Left).ToList();
            var rightPorts = node.Ports.OfType<LineFlowPort>()
                .Where(p => p.Alignment == PortAlignment.Right).ToList();

            int maxPorts = Math.Max(leftPorts.Count, rightPorts.Count);
            double portHeight = 16;
            double titleHeight = 20;
            double padding = 8;
            double nodeHeight = titleHeight + (maxPorts * portHeight) + padding;
            double nodeWidth = 180;

            double x = node.Position.X * scale;
            double y = -(node.Position.Y * scale);
            double w = nodeWidth * scale;
            double h = nodeHeight * scale;
            double sph = portHeight * scale;
            double sth = titleHeight * scale;

            DxfLine(x, y, x + w, y);
            DxfLine(x + w, y, x + w, y - h);
            DxfLine(x + w, y - h, x, y - h);
            DxfLine(x, y - h, x, y);
            DxfLine(x, y - sth, x + w, y - sth);
            DxfText(x + w / 2, y - sth + sth * 0.3, node.Title, 2.5, "NODES", 1);

            for (int i = 0; i < leftPorts.Count; i++)
            {
                double py = y - sth - (i * sph) - (sph * 0.5);
                double px = x;
                DxfText(px + 1, py - 1, leftPorts[i].Definition.Name, 1.8, "NODES", 0);
                portPositions[leftPorts[i].Id] = (px, py);
            }

            for (int i = 0; i < rightPorts.Count; i++)
            {
                double py = y - sth - (i * sph) - (sph * 0.5);
                double px = x + w;
                DxfText(px - 1, py - 1, rightPorts[i].Definition.Name, 1.8, "NODES", 2);
                portPositions[rightPorts[i].Id] = (px, py);
            }
        }

        foreach (var link in _diagram.Links)
        {
            if (link.Source.Model is not PortModel sourcePort) continue;
            if (link.Target?.Model is not PortModel targetPort) continue;
            if (!portPositions.TryGetValue(sourcePort.Id, out var srcPos)) continue;
            if (!portPositions.TryGetValue(targetPort.Id, out var tgtPos)) continue;

            var verts = link.Vertices;
            List<(double x, double y)> pts;

            // Vertices/label positions are in screen/port coordinate space.
            // Convert to DXF space using source port as reference:
            //   dxfX = (screenX - srcScreenX) * scale + srcPos.x
            //   dxfY = -(screenY - srcScreenY) * scale + srcPos.y  (Y axis is flipped in DXF)
            double srcScreenX = (sourcePort.Position?.X ?? 0) + (sourcePort.Size?.Width / 2 ?? 0);
            double srcScreenY = (sourcePort.Position?.Y ?? 0) + (sourcePort.Size?.Height / 2 ?? 0);

            (double x, double y) ToDxf(double sx, double sy) =>
                ((sx - srcScreenX) * scale + srcPos.x,
                 -(sy - srcScreenY) * scale + srcPos.y);

            if (verts.Count == 0)
            {
                // No vertices: centered elbow
                double midX = (srcPos.x + tgtPos.x) / 2;
                pts = new List<(double x, double y)> { srcPos, (midX, srcPos.y), (midX, tgtPos.y), tgtPos };
            }
            else if (verts.Count == 1)
            {
                // Simple H-V-H elbow using vertex X
                var (vx, _) = ToDxf(verts[0].Position.X, verts[0].Position.Y);
                pts = new List<(double x, double y)> { srcPos, (vx, srcPos.y), (vx, tgtPos.y), tgtPos };
            }
            else
            {
                // Multi-vertex: H-V-H-V-...-H matching the router's path
                var dv = verts.Select(v => ToDxf(v.Position.X, v.Position.Y)).ToList();

                pts = new List<(double x, double y)>();
                pts.Add(srcPos);
                pts.Add((dv[0].x, srcPos.y));
                for (int i = 0; i < dv.Count - 1; i++)
                {
                    pts.Add((dv[i].x, dv[i + 1].y));
                    pts.Add((dv[i + 1].x, dv[i + 1].y));
                }
                pts.Add((dv[^1].x, tgtPos.y));
                pts.Add(tgtPos);
            }

            for (int i = 0; i < pts.Count - 1; i++)
                DxfLine(pts[i].x, pts[i].y, pts[i + 1].x, pts[i + 1].y, "CONNECTIONS");

            if (link is ElbowLinkModel elbowLink && !string.IsNullOrEmpty(elbowLink.LabelText))
            {
                var labelPos = elbowLink.LabelNode != null
                    ? ToDxf(elbowLink.LabelNode.Position.X, elbowLink.LabelNode.Position.Y)
                    : PolylineMidpoint(pts);
                DxfText(labelPos.x, labelPos.y, elbowLink.LabelText, 2.0, "CONNECTIONS", 1);
            }
        }

        foreach (var box in _diagram.Nodes.OfType<BoxNode>())
        {
            double x = box.Position.X * scale;
            double y = -(box.Position.Y * scale);
            double w = (box.Size?.Width ?? 160) * scale;
            double h = (box.Size?.Height ?? 100) * scale;

            DxfLine(x, y, x + w, y, "ANNOTATIONS");
            DxfLine(x + w, y, x + w, y - h, "ANNOTATIONS");
            DxfLine(x + w, y - h, x, y - h, "ANNOTATIONS");
            DxfLine(x, y - h, x, y, "ANNOTATIONS");
        }

        foreach (var line in _diagram.Nodes.OfType<LineNode>())
        {
            double x1 = (line.Position.X + line.Start.X) * scale;
            double y1 = -((line.Position.Y + line.Start.Y) * scale);
            double x2 = (line.Position.X + line.End.X) * scale;
            double y2 = -((line.Position.Y + line.End.Y) * scale);

            DxfLine(x1, y1, x2, y2, "ANNOTATIONS");
        }

        foreach (var text in _diagram.Nodes.OfType<TextNode>())
        {
            double x = text.Position.X * scale;
            double y = -(text.Position.Y * scale);

            DxfText(x, y, text.Text, Math.Max(text.FontSize * scale, 1.0), "ANNOTATIONS", 0);
        }

        sb.AppendLine("0\nENDSEC");
        sb.AppendLine("0\nEOF");

        await JS.InvokeVoidAsync("saveAsFile", "diagram.dxf", sb.ToString());
    }

