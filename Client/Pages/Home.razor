@page "/"
@inject IJSRuntime JS
@inject HttpClient Http
@inject NavigationManager Nav
@using System.Text.Json

<div class="toolbar">
    <span class="app-title">Loopback</span>

    <div class="lf-menu-root">
        <button class="lf-menu-btn @(_openMenu == "file" ? "lf-menu-btn-active" : "")" @onclick='() => ToggleMenu("file")'>File</button>
        @if (_openMenu == "file")
        {
            <div class="lf-dropdown-menu">
                <div class="lf-dropdown-item" @onclick="() => { NewDiagram(); CloseMenus(); }">🆕 New</div>
                <div class="lf-dropdown-item" @onclick="async () => { await SaveDiagram(); CloseMenus(); }">💾 Save</div>
                <label class="lf-dropdown-item">
                    📂 Open <InputFile id="open-file-input" name="open-file-input" OnChange="async e => { await OpenDiagram(e); CloseMenus(); }" accept=".lf" />
                </label>
            </div>
        }
    </div>

    <div class="lf-menu-root">
        <button class="lf-menu-btn @(_openMenu == "tools" ? "lf-menu-btn-active" : "")" @onclick='() => ToggleMenu("tools")'>Tools</button>
        @if (_openMenu == "tools")
        {
            <div class="lf-dropdown-menu">
                <div class="lf-dropdown-item" @onclick="() => { AddLegend(); CloseMenus(); }">🏷 Legend</div>
                <div class="lf-dropdown-item @(_placementMode == "box" ? "lf-dropdown-item-active" : "")" @onclick='() => { TogglePlacement("box"); CloseMenus(); }'>▭ Box</div>
                <div class="lf-dropdown-item @(_placementMode == "line" ? "lf-dropdown-item-active" : "")" @onclick='() => { TogglePlacement("line"); CloseMenus(); }'>╱ Line</div>
                <div class="lf-dropdown-item @(_placementMode == "text" ? "lf-dropdown-item-active" : "")" @onclick='() => { TogglePlacement("text"); CloseMenus(); }'>T Text</div>
            </div>
        }
    </div>

    <div class="lf-menu-root">
        <button class="lf-menu-btn @(_openMenu == "export" ? "lf-menu-btn-active" : "")" @onclick='() => ToggleMenu("export")'>Export</button>
        @if (_openMenu == "export")
        {
            <div class="lf-dropdown-menu">
                <div class="lf-dropdown-item" @onclick="async () => { await ExportPdf(); CloseMenus(); }">📄 Export PDF</div>
                <div class="lf-dropdown-item" @onclick="async () => { await ExportDxf(); CloseMenus(); }">📐 Export DXF</div>
                <div class="lf-dropdown-item" @onclick="async () => { await ExportCableSchedule(); CloseMenus(); }">🧾 Cable Schedule (CSV)</div>
            </div>
        }
    </div>

    <button @onclick="Undo" disabled="@(!CanUndo)" title="Undo (Ctrl+Z)">↩ Undo</button>
    <button @onclick="Redo" disabled="@(!CanRedo)" title="Redo (Ctrl+Y)">↪ Redo</button>
    <button @onclick="DeleteSelected">Delete Selected</button>
    <input class="title-input" id="diagram-title" name="diagram-title" @bind="_diagramTitle" placeholder="Diagram title..." />
    @if (_isDirty)
    {
        <span class="lf-unsaved-badge" title="You have unsaved changes">● Unsaved</span>
    }

    <div class="lf-menu-root" style="margin-left:auto;">
        <button class="lf-menu-btn @(_openMenu == "account" ? "lf-menu-btn-active" : "")" @onclick='() => ToggleMenu("account")'>👤 @_currentUsername</button>
        @if (_openMenu == "account")
        {
            <div class="lf-dropdown-menu">
                <div class="lf-account-menu-user">@_currentUsername (@_currentRole)</div>
                @if (_currentRole == "Admin")
                {
                    <div class="lf-dropdown-item" @onclick='() => { CloseMenus(); Nav.NavigateTo("/users"); }'>👥 Manage Users</div>
                }
                <div class="lf-dropdown-item" @onclick="() => { OpenChangePassword(); CloseMenus(); }">🔑 Change Password</div>
                <div class="lf-dropdown-item" @onclick="async () => { await Logout(); CloseMenus(); }">🚪 Logout</div>
            </div>
        }
    </div>
</div>

@if (_openMenu != null)
{
    <div class="lf-menu-overlay" @onclick="CloseMenus"></div>
}

@if (!string.IsNullOrEmpty(_createdBy) || !string.IsNullOrEmpty(_modifiedBy))
{
    <div class="lf-file-meta">
        @if (!string.IsNullOrEmpty(_createdBy))
        {
            <span>Created by <strong>@_createdBy</strong>@(_createdAt is { } ca ? $" on {ca.ToLocalTime():MMM d, yyyy h:mm tt}" : "")</span>
        }
        @if (!string.IsNullOrEmpty(_modifiedBy))
        {
            <span> &middot; Last modified by <strong>@_modifiedBy</strong>@(_modifiedAt is { } ma ? $" on {ma.ToLocalTime():MMM d, yyyy h:mm tt}" : "")</span>
        }
    </div>
}

<div class="app-body" @onclick="HideContextMenu">
    <div class="side-panel">
        <div class="side-panel-header">Devices</div>

        <div class="lf-sort-row">
            <span class="lf-sort-label">Sort by</span>
            <select class="device-input lf-sort-select" id="device-sort-mode" name="device-sort-mode" @bind="_deviceSortMode">
                <option value="category">Type</option>
                <option value="manufacturer">Manufacturer</option>
            </select>
        </div>

        @foreach (var group in GroupedDevices)
        {
            <div class="device-category">@group.Key</div>
            @foreach (var device in group)
            {
                var idx = _devices.IndexOf(device);
                <div class="device-item @(_placementMode == "device" && _placingDevice == device ? "device-item-active" : "")" draggable="true"
                     @ondragstart="() => OnDeviceDragStart(device)"
                     @onclick="() => ToggleDevicePlacement(device)">
                    <div class="device-item-model">@device.Model</div>
                    <div class="device-item-mfr">@device.Manufacturer</div>
                    <div class="device-item-actions">
                        <button class="device-action-btn" @onclick:stopPropagation="true"
                                @onclick="() => StartEditDevice(idx)">✏</button>
                        <button class="device-action-btn device-action-delete" @onclick:stopPropagation="true"
                                @onclick="() => DeleteDevice(idx)">🗑</button>
                    </div>
                </div>
            }
        }

        <button class="add-device-btn" style="margin-top:16px;" @onclick="OpenAddDeviceModal">+ Add Device</button>
    </div>

    <div class="canvas-area @(_placementMode != "" ? "canvas-placing" : "")"
         @ondragover:preventDefault="true"
         @ondrop="OnCanvasDrop"
         @onclick="OnCanvasClick"
         @onmousemove="OnCanvasMouseMove"
         @onmouseup="OnCanvasMouseUp"
         @oncontextmenu:preventDefault="true">
        <CascadingValue Value="this" IsFixed="true">
            <CascadingValue Value="_diagram">
                <DiagramCanvas />
            </CascadingValue>
        </CascadingValue>
    </div>

    @if (_contextMenuVisible)
    {
        <div class="context-menu" style="left:@(_contextMenuX)px; top:@(_contextMenuY)px;">
            @if (_contextTarget == "node")
            {
                <div class="context-menu-item" @onclick="DuplicateContextNode">⧉ Duplicate</div>
                <div class="context-menu-item" @onclick="DeleteContextNode">🗑 Delete Node</div>
            }
            @if (_contextTarget == "link")
            {
                <div class="context-menu-item" @onclick="AddBend">➕ Add Bend</div>
                @if (_contextLink is ElbowLinkModel elm && elm.Vertices.Count > 1)
                {
                    <div class="context-menu-item" @onclick="RemoveLastBend">➖ Remove Last Bend</div>
                }
                <div class="context-menu-item" @onclick="OpenLabelModal">🏷 @(!string.IsNullOrEmpty((_contextLink as ElbowLinkModel)?.LabelText) ? "Edit Label" : "Add Label")</div>
                <div class="context-menu-item" @onclick="DeleteContextLink">🗑 Delete Connection</div>
            }
        </div>
    }
</div>

@if (_deviceModalOpen)
{
    <div class="lf-modal-overlay" @onclick="CancelEditDevice"></div>
    <div class="lf-modal" @onclick:stopPropagation="true">
        <div class="lf-modal-header">
            <span>@(_editingIndex >= 0 ? "Edit Device" : "Add Device")</span>
            <button class="lf-modal-close" @onclick="CancelEditDevice">✕</button>
        </div>

        <input class="device-input" id="new-device-manufacturer" name="new-device-manufacturer" @bind="_newManufacturer" placeholder="Manufacturer..." />
        <input class="device-input" id="new-device-model" name="new-device-model" @bind="_newModel" placeholder="Model number..." />
        <input class="device-input" id="new-device-category" name="new-device-category" @bind="_newCategory" placeholder="Category..." />

        <div class="port-list-header">Ports</div>
        @for (int i = 0; i < _newPorts.Count; i++)
        {
            var idx = i;
            <div class="port-row">
                <input class="port-input" id="@($"port-name-{idx}")" name="@($"port-name-{idx}")" @bind="_newPorts[idx].Name" placeholder="Name" />
                <select class="port-select" id="@($"port-type-{idx}")" name="@($"port-type-{idx}")" @bind="_newPorts[idx].Type">
                    <option>HDMI</option>
                    <option>SDI</option>
                    <option>Audio</option>
                    <option>Network</option>
                    <option>USB</option>
                    <option>IR</option>
                    <option>COM</option>
                    <option>Other</option>
                </select>
                <select class="port-select" id="@($"port-direction-{idx}")" name="@($"port-direction-{idx}")" @bind="_newPorts[idx].Direction">
                    <option>In</option>
                    <option>Out</option>
                    <option>Universal</option>
                </select>
                <button class="port-remove-btn" @onclick="() => RemovePort(idx)">✕</button>
            </div>
        }
        <button class="add-port-btn" @onclick="AddPort">+ Add Port</button>

        @if (_editingIndex >= 0)
        {
            <button class="add-device-btn" @onclick="SaveEditDevice">✔ Update Device</button>
            <button class="add-device-btn" style="border-color:#888;margin-top:2px;" @onclick="CancelEditDevice">✕ Cancel</button>
        }
        else
        {
            <button class="add-device-btn" @onclick="AddDevice">+ Add Device</button>
        }
    </div>
}

@if (_labelModalOpen)
{
    <div class="lf-modal-overlay" @onclick="CloseLabelModal"></div>
    <div class="lf-modal" style="width:260px;" @onclick:stopPropagation="true">
        <div class="lf-modal-header">
            <span>Connection Label</span>
            <button class="lf-modal-close" @onclick="CloseLabelModal">✕</button>
        </div>
        <input class="device-input" id="connection-label-input" name="connection-label-input" @bind="_labelText" placeholder="e.g. VID-005" autofocus />
        <button class="add-device-btn" @onclick="SaveLabel">✔ Save</button>
        @if (!string.IsNullOrEmpty(_labelTargetLink?.LabelText))
        {
            <button class="add-device-btn" style="border-color:#888;margin-top:2px;" @onclick="RemoveLabel">🗑 Remove Label</button>
        }
    </div>
}

@if (_passwordModalOpen)
{
    <div class="lf-modal-overlay" @onclick="CloseChangePassword"></div>
    <div class="lf-modal" style="width:280px;" @onclick:stopPropagation="true">
        <div class="lf-modal-header">
            <span>Change Password</span>
            <button class="lf-modal-close" @onclick="CloseChangePassword">✕</button>
        </div>
        <input type="password" class="device-input" id="current-password" name="current-password" @bind="_pwCurrent" placeholder="Current password" autocomplete="current-password" autofocus />
        <input type="password" class="device-input" id="new-password" name="new-password" @bind="_pwNew" placeholder="New password (min 8 characters)" autocomplete="new-password" />
        <input type="password" class="device-input" id="confirm-password" name="confirm-password" @bind="_pwConfirm" placeholder="Confirm new password" autocomplete="new-password" />
        @if (!string.IsNullOrEmpty(_pwError))
        {
            <div class="lf-users-error">@_pwError</div>
        }
        @if (!string.IsNullOrEmpty(_pwSuccess))
        {
            <div class="lf-pw-success">@_pwSuccess</div>
        }
        <button class="add-device-btn" @onclick="SubmitChangePassword" disabled="@_pwBusy">✔ Update Password</button>
    </div>
}

@code {
    private BlazorDiagram _diagram = null!;
    private List<DeviceDefinition> _devices = new();
    private DeviceDefinition? _draggingDevice = null;
    private string _diagramTitle = "Line Flow Diagram";

    private string _newManufacturer = "";
    private string _newModel = "";
    private string _newCategory = "";
    private List<PortDefinition> _newPorts = new();
    private int _editingIndex = -1;
    private bool _deviceModalOpen = false;

    private bool _contextMenuVisible = false;
    private double _contextMenuX = 0;
    private double _contextMenuY = 0;
    private string _contextTarget = "";
    private NodeModel? _contextNode = null;
    private BaseLinkModel? _contextLink = null;

    private bool _labelModalOpen = false;
    private ElbowLinkModel? _labelTargetLink = null;
    private string _labelText = "";

    private bool _passwordModalOpen = false;
    private string _pwCurrent = "";
    private string _pwNew = "";
    private string _pwConfirm = "";
    private string _pwError = "";
    private string _pwSuccess = "";
    private bool _pwBusy = false;

    private string _placementMode = ""; // "", "box", "line", "text", "device"
    private DeviceDefinition? _placingDevice = null;
    private string? _openMenu = null; // null, "file", "tools", "export", "account"

    private readonly List<string> _undoStack = new();
    private readonly List<string> _redoStack = new();
    private const int MaxUndoDepth = 50;
    private string? _pendingPointerSnapshot = null;
    private bool _restoringState = false;
    private bool CanUndo => _undoStack.Count > 0;
    private bool CanRedo => _redoStack.Count > 0;
    private bool _isDirty = false; // unsaved changes since last Save/Open/New
    private string? _clipboardJson = null; // in-app clipboard for copy/paste of nodes
    private int _pasteSequence = 0; // grows per paste so repeats don't stack exactly
    private string _deviceSortMode = "category"; // "category" or "manufacturer"

    private IEnumerable<IGrouping<string, DeviceDefinition>> GroupedDevices =>
        _deviceSortMode == "manufacturer"
            ? _devices.OrderBy(d => d.Manufacturer, StringComparer.OrdinalIgnoreCase).ThenBy(d => d.Model)
                .GroupBy(d => d.Manufacturer, StringComparer.OrdinalIgnoreCase)
            : _devices.OrderBy(d => d.Category, StringComparer.OrdinalIgnoreCase).ThenBy(d => d.Model)
                .GroupBy(d => d.Category, StringComparer.OrdinalIgnoreCase);

    private string _currentUsername = "";
    private string _currentRole = "";
    private string _createdBy = "";
    private DateTimeOffset? _createdAt = null;
    private string _modifiedBy = "";
    private DateTimeOffset? _modifiedAt = null;

    private record AuthStatus(bool HasUsers, bool IsAuthenticated, string? Username, string? Role);
    private NodeModel? _resizingNode = null;
    private ResizeHandle _resizeHandleKind = ResizeHandle.TopLeft;
    private Point _resizeStartMouse = new(0, 0);
    private Point _resizeStartPos = new(0, 0);
    private Blazor.Diagrams.Core.Geometry.Size _resizeStartSize = new(0, 0);
    private Point _resizeStartLineStart = new(0, 0);
    private Point _resizeStartLineEnd = new(0, 0);

    public enum ResizeHandle { TopLeft, TopRight, BottomLeft, BottomRight, LineStart, LineEnd }

    protected override async Task OnInitializedAsync()
    {
        _diagram = new BlazorDiagram();
        _diagram.Options.Links.DefaultRouter = new ElbowRouter();
        _diagram.Options.Links.DefaultPathGenerator = new Blazor.Diagrams.Core.PathGenerators.StraightPathGenerator();
        _diagram.RegisterComponent<LineFlowNode, LineFlowNodeWidget>();
        _diagram.RegisterComponent<LegendNode, LegendNodeWidget>();
        _diagram.RegisterComponent<BoxNode, BoxNodeWidget>();
        _diagram.RegisterComponent<LineNode, LineNodeWidget>();
        _diagram.RegisterComponent<TextNode, TextNodeWidget>();
        _diagram.RegisterComponent<ConnectionLabelNode, ConnectionLabelWidget>();
        _diagram.PointerDown += OnDiagramPointerDown;
        _diagram.Links.Added += (link) => OnLinkAdded((LinkModel)link);
        _diagram.Links.Removed += (link) =>
        {
            if (link is ElbowLinkModel elbow && elbow.LabelNode != null)
                _diagram.Nodes.Remove(elbow.LabelNode);
        };
        _diagram.Nodes.Removed += (node) =>
        {
            if (node is ConnectionLabelNode cln && cln.OwnerLink != null)
            {
                cln.OwnerLink.LabelText = null;
                cln.OwnerLink.LabelNode = null;
            }
        };

        var shortcuts = _diagram.GetBehavior<Blazor.Diagrams.Core.Behaviors.KeyboardShortcutsBehavior>();
        if (shortcuts != null)
        {
            // Wrap the library's default Delete so it lands on the undo stack first
            shortcuts.SetShortcut("Delete", ctrl: false, shift: false, alt: false, async d =>
            {
                if (_diagram.Nodes.Any(n => n.Selected) || _diagram.Links.Any(l => l.Selected))
                    PushUndoSnapshot();
                await Blazor.Diagrams.Core.Behaviors.KeyboardShortcutsDefaults.DeleteSelection(d);
                await InvokeAsync(StateHasChanged);
            });
            shortcuts.SetShortcut("z", ctrl: true, shift: false, alt: false, _ => { Undo(); return ValueTask.CompletedTask; });
            shortcuts.SetShortcut("y", ctrl: true, shift: false, alt: false, _ => { Redo(); return ValueTask.CompletedTask; });
            shortcuts.SetShortcut("c", ctrl: true, shift: false, alt: false, _ => { CopySelection(); return ValueTask.CompletedTask; });
            shortcuts.SetShortcut("v", ctrl: true, shift: false, alt: false, _ => { PasteClipboard(); return ValueTask.CompletedTask; });
        }

        await LoadDevices();
        await LoadAuthStatus();
    }

    private async Task LoadAuthStatus()
    {
        try
        {
            var status = await Http.GetFromJsonAsync<AuthStatus>("api/auth/status");
            _currentUsername = status?.Username ?? "";
            _currentRole = status?.Role ?? "";
        }
        catch
        {
            // If this fails the auth gate will redirect to /login on the next request anyway.
        }
    }

    private async Task Logout()
    {
        await Http.PostAsync("api/auth/logout", null);
        Nav.NavigateTo("/login", forceLoad: true);
    }

    private void OpenChangePassword()
    {
        _pwCurrent = _pwNew = _pwConfirm = _pwError = _pwSuccess = "";
        _pwBusy = false;
        _passwordModalOpen = true;
    }

    private void CloseChangePassword()
    {
        _passwordModalOpen = false;
    }

    private async Task SubmitChangePassword()
    {
        _pwError = "";
        _pwSuccess = "";

        if (_pwNew.Length < 8)
        {
            _pwError = "New password must be at least 8 characters.";
            return;
        }
        if (_pwNew != _pwConfirm)
        {
            _pwError = "New passwords do not match.";
            return;
        }

        _pwBusy = true;
        try
        {
            var res = await Http.PostAsJsonAsync("api/auth/change-password",
                new { currentPassword = _pwCurrent, newPassword = _pwNew });
            if (res.IsSuccessStatusCode)
            {
                _pwSuccess = "Password updated.";
                _pwCurrent = _pwNew = _pwConfirm = "";
            }
            else
            {
                var body = await res.Content.ReadFromJsonAsync<ErrorBody>();
                _pwError = body?.Error ?? "Could not change password.";
            }
        }
        catch
        {
            _pwError = "Could not reach the server. Please try again.";
        }
        finally
        {
            _pwBusy = false;
        }
    }

    private record ErrorBody(string? Error);

    private void OnLinkAdded(LinkModel link)
    {
        if (link is ElbowLinkModel elbowLink)
        {
            SetupElbowLink(elbowLink);
            return;
        }

        link.TargetChanged += async (l, _, newTarget) =>
        {
            if (newTarget?.Model is not PortModel targetPort) return;
            if (l.Source.Model is not PortModel sourcePort) return;

            var sourceDir = (sourcePort as LineFlowPort)?.GetDirection() ?? "Universal";
            var targetDir = (targetPort as LineFlowPort)?.GetDirection() ?? "Universal";

            bool valid =
                (sourceDir == "In" && (targetDir == "Out" || targetDir == "Universal")) ||
                (sourceDir == "Out" && (targetDir == "In" || targetDir == "Universal")) ||
                (sourceDir == "Universal");

            await InvokeAsync(async () =>
            {
                _diagram.Links.Remove(l);
                if (!valid) { StateHasChanged(); return; }

                PushUndoSnapshot();
                var elbow = new ElbowLinkModel(sourcePort, targetPort);
                _diagram.Links.Add(elbow); // fires OnLinkAdded → SetupElbowLink

                await Task.Delay(100);

                if (sourcePort.Position == null || targetPort.Position == null) return;

                double srcX = sourcePort.Position.X + (sourcePort.Size?.Width / 2 ?? 0);
                double tgtX = targetPort.Position.X + (targetPort.Size?.Width / 2 ?? 0);
                double srcY = sourcePort.Position.Y + (sourcePort.Size?.Height / 2 ?? 0);
                double tgtY = targetPort.Position.Y + (targetPort.Size?.Height / 2 ?? 0);
                double midX = elbow.MidX ?? (srcX + tgtX) / 2;
                double centerY = (srcY + tgtY) / 2;

                elbow.Vertices.Add(new LinkVertexModel(elbow, new Point(midX, centerY)));
                elbow.Refresh();
            });
        };
    }

    private void SetupElbowLink(ElbowLinkModel elbow)
    {
        var portType = (elbow.Source.Model as LineFlowPort)?.Definition.Type ?? "Other";
        var color = ElbowLinkModel.ColorForType(portType);
        elbow.Color = color;
        elbow.SelectedColor = color;

        bool updating = false;
        elbow.Changed += _ =>
        {
            if (updating || elbow.Vertices.Count == 0) return;
            if (elbow.Source.Model is not PortModel srcPort || elbow.Target?.Model is not PortModel tgtPort) return;
            if (srcPort.Position == null || tgtPort.Position == null) return;

            // Lock vertex[0] Y so the first handle only slides left/right
            updating = true;
            double srcY = srcPort.Position.Y + (srcPort.Size?.Height / 2 ?? 0);
            double nextY = elbow.Vertices.Count > 1
                ? elbow.Vertices[1].Position.Y
                : tgtPort.Position.Y + (tgtPort.Size?.Height / 2 ?? 0);
            elbow.Vertices[0].SetPosition(elbow.Vertices[0].Position.X, (srcY + nextY) / 2);
            updating = false;
        };
    }

    private void AddBend()
    {
        if (_contextLink is not ElbowLinkModel elbow) return;
        _contextMenuVisible = false;
        if (elbow.Target?.Model is not PortModel tgtPort || tgtPort.Position == null) return;

        PushUndoSnapshot();

        double tgtX = tgtPort.Position.X + (tgtPort.Size?.Width / 2 ?? 0);
        double tgtY = tgtPort.Position.Y + (tgtPort.Size?.Height / 2 ?? 0);

        double newX, newY;
        if (elbow.Vertices.Count > 0)
        {
            var last = elbow.Vertices[^1];
            newX = (last.Position.X + tgtX) / 2;
            newY = (last.Position.Y + tgtY) / 2;
        }
        else { newX = tgtX; newY = tgtY; }

        elbow.Vertices.Add(new LinkVertexModel(elbow, new Point(newX, newY)));
        elbow.Refresh();
    }

    private void RemoveLastBend()
    {
        if (_contextLink is not ElbowLinkModel elbow || elbow.Vertices.Count <= 1) return;
        _contextMenuVisible = false;
        PushUndoSnapshot();
        elbow.Vertices.RemoveAt(elbow.Vertices.Count - 1);
        elbow.Refresh();
    }

    private void OpenLabelModal()
    {
        if (_contextLink is not ElbowLinkModel elbow) return;
        _contextMenuVisible = false;
        _labelTargetLink = elbow;
        _labelText = elbow.LabelText ?? "";
        _labelModalOpen = true;
    }

    private void SaveLabel()
    {
        if (_labelTargetLink is ElbowLinkModel elbow)
        {
            var text = _labelText.Trim();
            if (text != (elbow.LabelText ?? ""))
                PushUndoSnapshot();
            if (string.IsNullOrEmpty(text))
            {
                RemoveLabelNode(elbow);
            }
            else
            {
                elbow.LabelText = text;
                if (elbow.LabelNode == null)
                {
                    var node = new ConnectionLabelNode(ComputeLinkMidpoint(elbow)) { Text = text, OwnerLink = elbow };
                    elbow.LabelNode = node;
                    _diagram.Nodes.Add(node);
                }
                else
                {
                    elbow.LabelNode.Text = text;
                    elbow.LabelNode.Refresh();
                }
            }
        }
        CloseLabelModal();
    }

    private void RemoveLabel()
    {
        if (_labelTargetLink is ElbowLinkModel elbow)
        {
            if (!string.IsNullOrEmpty(elbow.LabelText))
                PushUndoSnapshot();
            RemoveLabelNode(elbow);
        }
        CloseLabelModal();
    }

    private void RemoveLabelNode(ElbowLinkModel elbow)
    {
        elbow.LabelText = null;
        if (elbow.LabelNode != null)
        {
            _diagram.Nodes.Remove(elbow.LabelNode);
            elbow.LabelNode = null;
        }
    }

    private void CloseLabelModal()
    {
        _labelModalOpen = false;
        _labelTargetLink = null;
        _labelText = "";
    }

    // Best-effort midpoint of the link's current route, for placing a freshly-created label.
    // Falls back to the node midpoint if port positions aren't measured yet (e.g. right after
    // a bulk file load, before the first render pass).
    private Point ComputeLinkMidpoint(ElbowLinkModel elbow)
    {
        var route = new ElbowRouter().GetRoute(_diagram, elbow);
        double totalLength = 0;
        for (int i = 0; i < route.Length - 1; i++)
            totalLength += Math.Sqrt(Math.Pow(route[i + 1].X - route[i].X, 2) + Math.Pow(route[i + 1].Y - route[i].Y, 2));

        // A zero-length "route" means the ports haven't been measured by the browser yet
        // (freshly created PortModel.Position defaults to (0,0) rather than null) — fall
        // through to the node-midpoint estimate below instead of anchoring on (0,0).
        if (route.Length >= 2 && totalLength > 0.01)
        {
            double target = totalLength / 2;
            double covered = 0;
            for (int i = 0; i < route.Length - 1; i++)
            {
                double segLen = Math.Sqrt(Math.Pow(route[i + 1].X - route[i].X, 2) + Math.Pow(route[i + 1].Y - route[i].Y, 2));
                if (segLen <= 0) continue;
                if (covered + segLen >= target)
                {
                    double t = (target - covered) / segLen;
                    return new Point(route[i].X + (route[i + 1].X - route[i].X) * t, route[i].Y + (route[i + 1].Y - route[i].Y) * t);
                }
                covered += segLen;
            }
            return route[^1];
        }

        var srcNode = (elbow.Source.Model as PortModel)?.Parent;
        var tgtNode = (elbow.Target?.Model as PortModel)?.Parent;
        if (srcNode != null && tgtNode != null)
            return new Point((srcNode.Position.X + tgtNode.Position.X) / 2, (srcNode.Position.Y + tgtNode.Position.Y) / 2);
        return new Point(0, 0);
    }

    private void PushUndoSnapshot() => PushUndoSnapshot(SerializeDiagramState());

    private void PushUndoSnapshot(string snapshot)
    {
        if (_restoringState) return;
        _undoStack.Add(snapshot);
        if (_undoStack.Count > MaxUndoDepth) _undoStack.RemoveAt(0);
        _redoStack.Clear();
        MarkDirty();
    }

    // Tracks whether the canvas differs from the last Save/Open/New. Mirrored to a JS flag
    // so the beforeunload handler in index.html can warn before the tab closes. This is a
    // conservative flag (an edit-then-undo-back leaves it set) — we prefer a false "unsaved"
    // warning over silently losing work.
    private void MarkDirty()
    {
        if (_isDirty) return;
        _isDirty = true;
        _ = JS.InvokeVoidAsync("setUnsavedChanges", true);
    }

    private void MarkClean()
    {
        _isDirty = false;
        _ = JS.InvokeVoidAsync("setUnsavedChanges", false);
    }

    private void Undo()
    {
        if (_undoStack.Count == 0) return;
        var snapshot = _undoStack[^1];
        _undoStack.RemoveAt(_undoStack.Count - 1);
        _redoStack.Add(SerializeDiagramState());
        RestoreDiagramState(snapshot);
    }

    private void Redo()
    {
        if (_redoStack.Count == 0) return;
        var snapshot = _redoStack[^1];
        _redoStack.RemoveAt(_redoStack.Count - 1);
        _undoStack.Add(SerializeDiagramState());
        RestoreDiagramState(snapshot);
    }

    private void RestoreDiagramState(string json)
    {
        _restoringState = true;
        try
        {
            _pendingPointerSnapshot = null;
            LoadDiagramJson(json);
        }
        finally { _restoringState = false; }
        MarkDirty();
        InvokeAsync(StateHasChanged);
    }

    // Drag-style edits (node moves, bend drags, resizes, text edits) capture a snapshot
    // when the gesture starts and commit it as an undo step only if the diagram actually
    // changed by the time the gesture ends.
    public void CapturePointerSnapshot()
    {
        if (_restoringState) return;
        _pendingPointerSnapshot = SerializeDiagramState();
    }

    public void CommitPointerSnapshot()
    {
        if (_pendingPointerSnapshot == null) return;
        var pending = _pendingPointerSnapshot;
        _pendingPointerSnapshot = null;
        if (SerializeDiagramState() != pending)
            PushUndoSnapshot(pending);
    }

    private void OnDiagramPointerDown(Model? model, Blazor.Diagrams.Core.Events.PointerEventArgs args)
    {
        if (args.Button == 0 && model is NodeModel or BaseLinkModel or LinkVertexModel)
            CapturePointerSnapshot();

        if (args.Button == 2)
        {
            if (model is NodeModel node)
            {
                _contextTarget = "node";
                _contextNode = node;
                _contextLink = null;
                ShowContextMenu(args.ClientX, args.ClientY);
            }
            else if (model is BaseLinkModel link)
            {
                _contextTarget = "link";
                _contextLink = link;
                _contextNode = null;
                ShowContextMenu(args.ClientX, args.ClientY);
            }
        }
    }

    private void ShowContextMenu(double x, double y)
    {
        _contextMenuX = x;
        _contextMenuY = y;
        _contextMenuVisible = true;
        StateHasChanged();
    }

    private void HideContextMenu()
    {
        _contextMenuVisible = false;
        _contextNode = null;
        _contextLink = null;
    }

    private void DeleteContextNode()
    {
        if (_contextNode != null)
        {
            PushUndoSnapshot();
            _diagram.Nodes.Remove(_contextNode);
        }
        _contextMenuVisible = false;
        _contextNode = null;
    }

    private void DeleteContextLink()
    {
        if (_contextLink != null)
        {
            PushUndoSnapshot();
            _diagram.Links.Remove(_contextLink);
        }
        _contextMenuVisible = false;
        _contextLink = null;
    }

    private void DeleteSelected()
    {
        if (!_diagram.Nodes.Any(n => n.Selected) && !_diagram.Links.Any(l => l.Selected)) return;
        PushUndoSnapshot();
        foreach (var node in _diagram.Nodes.Where(n => n.Selected).ToList())
            _diagram.Nodes.Remove(node);
        foreach (var link in _diagram.Links.Where(l => l.Selected).ToList())
            _diagram.Links.Remove(link);
    }

    private void AddLegend()
    {
        var usedTypes = _diagram.Links
            .Select(l => (l.Source.Model as LineFlowPort)?.Definition.Type)
            .Where(t => t != null)
            .Select(t => t!)
            .Distinct()
            .OrderBy(t => t)
            .ToList();

        if (usedTypes.Count == 0) return;

        PushUndoSnapshot();
        var entries = usedTypes
            .Select(t => (t, ElbowLinkModel.ColorForType(t)))
            .ToList();

        // Update existing legend if present, otherwise create one
        var existing = _diagram.Nodes.OfType<LegendNode>().FirstOrDefault();
        if (existing != null)
        {
            existing.Entries = entries;
            existing.Refresh();
            return;
        }

        var legend = new LegendNode(new Point(20, 20)) { Entries = entries };
        _diagram.Nodes.Add(legend);
    }

    private void TogglePlacement(string mode)
    {
        _placementMode = _placementMode == mode ? "" : mode;
        _placingDevice = null;
    }

    private void ToggleDevicePlacement(DeviceDefinition device)
    {
        if (_placementMode == "device" && _placingDevice == device)
        {
            _placementMode = "";
            _placingDevice = null;
        }
        else
        {
            _placementMode = "device";
            _placingDevice = device;
        }
    }

    private void ToggleMenu(string name)
    {
        _openMenu = _openMenu == name ? null : name;
    }

    private void CloseMenus()
    {
        _openMenu = null;
    }

    private void OnCanvasClick(MouseEventArgs e)
    {
        HideContextMenu();

        if (_placementMode == "")
            return;

        PushUndoSnapshot();
        var point = new Point(e.ClientX - 220, e.ClientY - 48);

        switch (_placementMode)
        {
            case "box":
                _diagram.Nodes.Add(new BoxNode(point));
                break;
            case "line":
                _diagram.Nodes.Add(new LineNode(point));
                break;
            case "text":
                _diagram.Nodes.Add(new TextNode(point) { Editing = true });
                break;
            case "device":
                if (_placingDevice != null)
                    _diagram.Nodes.Add(new LineFlowNode(point, _placingDevice));
                break;
        }

        _placementMode = "";
        _placingDevice = null;
    }

    public void StartResize(NodeModel node, ResizeHandle handle, MouseEventArgs e)
    {
        CapturePointerSnapshot();
        _resizingNode = node;
        _resizeHandleKind = handle;
        _resizeStartMouse = new Point(e.ClientX, e.ClientY);
        _resizeStartPos = node.Position;
        _resizeStartSize = node.Size ?? new Blazor.Diagrams.Core.Geometry.Size(160, 100);

        if (node is LineNode line)
        {
            _resizeStartLineStart = line.Start;
            _resizeStartLineEnd = line.End;
        }
    }

    private void OnCanvasMouseMove(MouseEventArgs e)
    {
        if (_resizingNode == null) return;

        double zoom = _diagram.Zoom == 0 ? 1 : _diagram.Zoom;
        double dx = (e.ClientX - _resizeStartMouse.X) / zoom;
        double dy = (e.ClientY - _resizeStartMouse.Y) / zoom;

        if (_resizingNode is LineNode line)
        {
            var fixedAbs = _resizeHandleKind == ResizeHandle.LineStart
                ? new Point(_resizeStartPos.X + _resizeStartLineEnd.X, _resizeStartPos.Y + _resizeStartLineEnd.Y)
                : new Point(_resizeStartPos.X + _resizeStartLineStart.X, _resizeStartPos.Y + _resizeStartLineStart.Y);
            var movingAbs = _resizeHandleKind == ResizeHandle.LineStart
                ? new Point(_resizeStartPos.X + _resizeStartLineStart.X + dx, _resizeStartPos.Y + _resizeStartLineStart.Y + dy)
                : new Point(_resizeStartPos.X + _resizeStartLineEnd.X + dx, _resizeStartPos.Y + _resizeStartLineEnd.Y + dy);

            double minX = Math.Min(fixedAbs.X, movingAbs.X);
            double minY = Math.Min(fixedAbs.Y, movingAbs.Y);
            double maxX = Math.Max(fixedAbs.X, movingAbs.X);
            double maxY = Math.Max(fixedAbs.Y, movingAbs.Y);

            line.SetPosition(minX, minY);
            line.Size = new Blazor.Diagrams.Core.Geometry.Size(Math.Max(maxX - minX, 1), Math.Max(maxY - minY, 1));

            if (_resizeHandleKind == ResizeHandle.LineStart)
            {
                line.Start = new Point(movingAbs.X - minX, movingAbs.Y - minY);
                line.End = new Point(fixedAbs.X - minX, fixedAbs.Y - minY);
            }
            else
            {
                line.End = new Point(movingAbs.X - minX, movingAbs.Y - minY);
                line.Start = new Point(fixedAbs.X - minX, fixedAbs.Y - minY);
            }
            line.Refresh();
            return;
        }

        if (_resizingNode is BoxNode box)
        {
            double newX = _resizeStartPos.X, newY = _resizeStartPos.Y;
            double newW = _resizeStartSize.Width, newH = _resizeStartSize.Height;

            switch (_resizeHandleKind)
            {
                case ResizeHandle.TopLeft: newX += dx; newY += dy; newW -= dx; newH -= dy; break;
                case ResizeHandle.TopRight: newY += dy; newW += dx; newH -= dy; break;
                case ResizeHandle.BottomLeft: newX += dx; newW -= dx; newH += dy; break;
                case ResizeHandle.BottomRight: newW += dx; newH += dy; break;
            }

            if (newW < 30) { if (_resizeHandleKind is ResizeHandle.TopLeft or ResizeHandle.BottomLeft) newX = _resizeStartPos.X + _resizeStartSize.Width - 30; newW = 30; }
            if (newH < 24) { if (_resizeHandleKind is ResizeHandle.TopLeft or ResizeHandle.TopRight) newY = _resizeStartPos.Y + _resizeStartSize.Height - 24; newH = 24; }

            box.SetPosition(newX, newY);
            box.Size = new Blazor.Diagrams.Core.Geometry.Size(newW, newH);
            box.Refresh();
        }
    }

    private void OnCanvasMouseUp(MouseEventArgs e)
    {
        _resizingNode = null;
        CommitPointerSnapshot();
    }

    private async Task LoadDevices()
    {
        try
        {
            var devices = await Http.GetFromJsonAsync<List<DeviceDefinition>>("api/devices");
            if (devices != null) _devices = devices;
        }
        catch (Exception ex)
        {
            Console.WriteLine("Failed to load devices: " + ex.Message);
        }
    }

    private void AddPort()
    {
        _newPorts.Add(new PortDefinition { Name = "", Type = "HDMI", Direction = "In" });
    }

    private void RemovePort(int index)
    {
        _newPorts.RemoveAt(index);
    }

    private async Task AddDevice()
    {
        if (string.IsNullOrWhiteSpace(_newModel)) return;

        var device = new DeviceDefinition
        {
            Manufacturer = _newManufacturer,
            Model = _newModel,
            Category = _newCategory,
            Ports = _newPorts.ToList()
        };

        try
        {
            var response = await Http.PostAsJsonAsync("api/devices", device);
            if (response.IsSuccessStatusCode)
            {
                _devices.Add(device);
                _newManufacturer = "";
                _newModel = "";
                _newCategory = "";
                _newPorts.Clear();
                _deviceModalOpen = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Failed to add device: " + ex.Message);
        }
    }

    private void OpenAddDeviceModal()
    {
        CancelEditDevice();
        _deviceModalOpen = true;
    }

    private void StartEditDevice(int index)
    {
        var d = _devices[index];
        _editingIndex = index;
        _newManufacturer = d.Manufacturer;
        _newModel = d.Model;
        _newCategory = d.Category;
        _newPorts = d.Ports.Select(p => new PortDefinition { Name = p.Name, Type = p.Type, Direction = p.Direction }).ToList();
        _deviceModalOpen = true;
        StateHasChanged();
    }

    private async Task SaveEditDevice()
    {
        if (string.IsNullOrWhiteSpace(_newModel) || _editingIndex < 0) return;

        var device = new DeviceDefinition
        {
            Manufacturer = _newManufacturer,
            Model = _newModel,
            Category = _newCategory,
            Ports = _newPorts.ToList()
        };

        try
        {
            var response = await Http.PutAsJsonAsync($"api/devices/{_editingIndex}", device);
            if (response.IsSuccessStatusCode)
            {
                _devices[_editingIndex] = device;
                CancelEditDevice();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Failed to update device: " + ex.Message);
        }
    }

    private void CancelEditDevice()
    {
        _editingIndex = -1;
        _newManufacturer = "";
        _newModel = "";
        _newCategory = "";
        _newPorts.Clear();
        _deviceModalOpen = false;
        StateHasChanged();
    }

    private async Task DeleteDevice(int index)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/devices/{index}");
            if (response.IsSuccessStatusCode)
            {
                _devices.RemoveAt(index);
                if (_editingIndex == index) CancelEditDevice();
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Failed to delete device: " + ex.Message);
        }
    }

